DJANGO_SECRET_KEY=replace-with-strong-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (STEP 7.5)
# 로컬 dev 환경: socket peer 인증을 쓸 경우 DB_USER=현재 OS 사용자, DB_HOST/DB_PASSWORD 빈값
# TCP 인증을 쓸 경우 DB_HOST=localhost + DB_PASSWORD 채움
DB_ENGINE=django.db.backends.postgresql
DB_NAME=munbeop
DB_USER=munbeop_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
